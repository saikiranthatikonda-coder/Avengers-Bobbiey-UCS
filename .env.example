# --- JARVIS config ---

# Get a free key at https://newsapi.org/register
NEWSAPI_KEY=

# Bind address (loopback only by default)
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8765

# Voice response — JARVIS speaks every agent reply out loud (requires pyttsx3)
JARVIS_TTS=1
JARVIS_VOICE_NAME=Microsoft David Desktop
JARVIS_VOICE_RATE=180

# Wake word + STT loop ("hey jarvis"). Requires the optional deps in requirements.txt.
JARVIS_VOICE=0

# Path to the Claude Code CLI (used as the LLM brain via `claude -p`)
CLAUDE_BIN=claude
